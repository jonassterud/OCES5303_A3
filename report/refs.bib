@article{article:frenger_2013,
    author={Frenger, I. and Gruber, N. and Knutti, R. and M{\"u}nnich, M.},
    title={Imprint of Southern Ocean eddies on winds, clouds and rainfall},
    journal={Nature Geoscience},
    year={2013},
    month={Aug},
    day={01},
    volume={6},
    number={8},
    pages={608-612},
    abstract={Owing to the turbulent nature of the ocean, mesoscale eddies are omnipresent. An analysis of atmospheric conditions associated with several hundred thousand eddies in the Southern Ocean suggests that the transitory sea surface temperature fronts associated with these eddies alter near-surface winds, clouds and rainfall.},
    issn={1752-0908},
    doi={10.1038/ngeo1863},
    url={https://doi.org/10.1038/ngeo1863}
}
